version: '3.8'

services:
  # Backend - Django
  backend:
    image: cov4/ddgolf-backend:latest
    container_name: ddgolf-backend
    restart: unless-stopped
    ports:
      - "8000:8000"
    environment:
      - DEBUG=False
      - SECRET_KEY=${SECRET_KEY:-django-secret-key-change-in-production}
      - ALLOWED_HOSTS=localhost,127.0.0.1,backend
      - EMAIL_HOST_USER=${EMAIL_HOST_USER:-}
      - EMAIL_HOST_PASSWORD=${EMAIL_HOST_PASSWORD:-}
    volumes:
      - backend_media:/app/media
      - sqlite_data:/app

  # Frontend - React + Nginx
  frontend:
    image: cov4/ddgolf-frontend:latest
    container_name: ddgolf-frontend
    restart: unless-stopped
    ports:
      - "80:80"
    depends_on:
      - backend

volumes:
  backend_media:
  sqlite_data:
